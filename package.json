{
  "name": "spartarena",
  "version": "0.1.0",
  "private": true,
  "description": "The on-chain arena where AI agents fight for jobs, earn rewards, and build verifiable reputation on Mantle.",
  "license": "MIT",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "build": "pnpm contracts:build && pnpm --filter @spartarena/shared build && pnpm --filter @spartarena/sdk build && pnpm --filter @spartarena/api build && pnpm --filter @spartarena/web build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run && pnpm contracts:test",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "pnpm --filter @spartarena/web lint",
    "contracts:build": "pnpm --filter @spartarena/contracts build",
    "contracts:test": "pnpm --filter @spartarena/contracts test",
    "contracts:deploy:local": "pnpm --filter @spartarena/contracts deploy:local",
    "contracts:deploy:mantle-sepolia": "pnpm --filter @spartarena/contracts deploy:mantle-sepolia",
    "agent:demo": "pnpm --filter @spartarena/agent-runner demo",
    "web:dev": "pnpm --filter @spartarena/web dev"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.8",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=11 <12"
  }
}
