# @spartarena/byreal-adapter — environment

# Byreal REST API base URL (Solana DEX; no auth required for reads/quotes).
# Defaults to the value below when unset.
BYREAL_API_URL=https://api2.byreal.io

# Set to true|1|yes|on to use the deterministic OFFLINE mock instead of the
# real Byreal REST client. Leave unset/false in production so the default code
# path hits the REAL Byreal API.
BYREAL_MOCK=false
