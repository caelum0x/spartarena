# ─────────────────────────────────────────────────────────────────────────────
# @spartarena/agent-runner — environment
# Copy to .env and fill in. NEVER commit real secrets.
# Default code path hits REAL APIs. Mocks/offline paths are opt-in via flags.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM provider selection ──────────────────────────────────────────────────
# Selection order in getProvider():
#   ANTHROPIC_API_KEY -> Anthropic, else OPENAI_API_KEY -> OpenAI,
#   else LLM_PROVIDER=mock -> deterministic mock (offline/tests only),
#   else a clear configuration error is thrown.

# Anthropic Messages API (preferred when set)
ANTHROPIC_API_KEY=
# Default: claude-opus-4-8
ANTHROPIC_MODEL=claude-opus-4-8
# Max output tokens for Anthropic (default 2048)
ANTHROPIC_MAX_TOKENS=2048

# OpenAI Chat Completions API (used when Anthropic key absent)
OPENAI_API_KEY=
# Default: gpt-4o
OPENAI_MODEL=gpt-4o
# Optional OpenAI-compatible base URL (e.g. an Azure/OpenRouter gateway).
# Default: https://api.openai.com/v1
OPENAI_BASE_URL=

# Shared LLM tuning
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_MS=60000
# Force the offline deterministic mock provider (tests / no-key demos only):
#   LLM_PROVIDER=mock
LLM_PROVIDER=

# ── Mantle chain reads (AlphaSentinel) ──────────────────────────────────────
# RPC endpoint — REQUIRED for real reads (getBalance, getLogs, getCode).
#   Mainnet: https://rpc.mantle.xyz   Sepolia: https://rpc.sepolia.mantle.xyz
NEXT_PUBLIC_MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
# Chain id: 5000 mainnet, 5003 sepolia, 31337 local anvil.
NEXT_PUBLIC_CHAIN_ID=5003
# Explorer base URL for evidence links.
NEXT_PUBLIC_MANTLE_EXPLORER_URL=https://sepolia.mantlescan.xyz
# Etherscan-V2 API key (one key, all chains) — enables preferred tokentx reads.
# Without it the reader falls back to viem getLogs Transfer scanning.
ETHERSCAN_API_KEY=
ETHERSCAN_TIMEOUT_MS=15000
# Offline deterministic Mantle path — ONLY when no RPC/key is available:
#   MANTLE_OFFLINE=true
MANTLE_OFFLINE=

# ── Market + yield data (YieldStrategist) ───────────────────────────────────
# CoinGecko demo key (optional; raises rate limits). No key = public endpoint.
COINGECKO_API_KEY=
# DefiLlama needs no key. Offline deterministic asset path — tests/demos only:
#   ASSETS_OFFLINE=true
ASSETS_OFFLINE=

# ── Byreal pool analysis (ByrealPoolAnalyst) ────────────────────────────────
# Byreal REST API base URL (Solana DEX; no auth for reads/quotes). Defaults to
# https://api2.byreal.io when unset.
BYREAL_API_URL=https://api2.byreal.io
# Set to true|1|yes|on to use the deterministic OFFLINE Byreal mock instead of
# the real REST client (tests / no-network demos only). Leave unset/false in
# production so the default code path hits the REAL Byreal API.
BYREAL_MOCK=

# ── Contract audit (ContractAuditor) ────────────────────────────────────────
# ContractInspector reads contract bytecode (getCode), native balance
# (getBalance) and runs static opcode heuristics over the bytecode. It uses
# NEXT_PUBLIC_MANTLE_RPC_URL above for real reads, or the deterministic offline
# path when MANTLE_OFFLINE=true (set in the Mantle chain reads section above).

# ── On-chain settlement (only for `pnpm demo:onchain`) ──────────────────────
BACKEND_SIGNER_PRIVATE_KEY=
NEXT_PUBLIC_DECISION_LEDGER_ADDRESS=
NEXT_PUBLIC_TASK_ESCROW_ADDRESS=
NEXT_PUBLIC_REPUTATION_ENGINE_ADDRESS=

# ── Demo ids (optional) ─────────────────────────────────────────────────────
DEMO_TASK_ID=1
DEMO_AGENT_ID=1
DEMO_YIELD_TASK_ID=2
DEMO_YIELD_AGENT_ID=2
DEMO_BYREAL_TASK_ID=3
DEMO_BYREAL_AGENT_ID=3
DEMO_AUDIT_TASK_ID=4
DEMO_AUDIT_AGENT_ID=4
