# --- SpartArena Web (apps/web) ---
#
# The DEFAULT data path is REAL: the app talks to the live @spartarena/api
# backend and reads/writes on-chain via wagmi/viem using the contract addresses
# below. Mock fixtures are OPT-IN only (NEXT_PUBLIC_USE_MOCKS=true).

# App identity
NEXT_PUBLIC_APP_NAME=SpartArena
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend API (the @spartarena/api service). Real backend by default; the client
# validates the { success, data, error, meta } envelope with zod and surfaces a
# real error/empty state when unreachable (unless NEXT_PUBLIC_USE_MOCKS=true).
# Also read server-side by the dynamic OG route (/api/og?agentId=) to render
# Spartan share cards, and by the footer "Alerts" indicator
# (GET /notifications/status — degrades gracefully when unimplemented).
NEXT_PUBLIC_API_URL=http://localhost:4000

# Data source toggle. Leave false (or unset) for the real production path.
# Set to "true" ONLY for offline/demo development to serve rich mock fixtures.
NEXT_PUBLIC_USE_MOCKS=false

# Chain
NEXT_PUBLIC_CHAIN_ID=5003
NEXT_PUBLIC_MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
NEXT_PUBLIC_MANTLE_EXPLORER_URL=https://sepolia.mantlescan.xyz

# Contract addresses (from packages/contracts/deployments/<chainId>.json after
# deploy). All five must be set to enable on-chain writes (register agent,
# create battle, verify, release payment). Leave blank to run read-only.
NEXT_PUBLIC_AGENT_REGISTRY_ADDRESS=
NEXT_PUBLIC_TASK_ESCROW_ADDRESS=
NEXT_PUBLIC_DECISION_LEDGER_ADDRESS=
NEXT_PUBLIC_REPUTATION_ENGINE_ADDRESS=
NEXT_PUBLIC_SKILL_REGISTRY_ADDRESS=
NEXT_PUBLIC_AGENT_STAKING_ADDRESS=

# Optional: WalletConnect project id (the injected connector works without it).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Server-only (NOT exposed to the browser) ---
# Optional CoinGecko demo key, used server-side by the /api/prices route so the
# key never reaches the client. Prices fall back to keyless CoinGecko if unset.
COINGECKO_API_KEY=
