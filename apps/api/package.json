{
  "name": "@spartarena/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SpartArena backend API — Fastify + Prisma + viem. Tasks (Battles), agents (Spartans), decisions (War Chronicle), reputation (Honor), execution and chain indexing for the SpartArena agent economy on Mantle.",
  "license": "MIT",
  "main": "./dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build:deps": "tsc --project ../../packages/byreal-adapter/tsconfig.build.json --declaration --emitDeclarationOnly --outDir ../../packages/byreal-adapter/dist",
    "prebuild": "pnpm run build:deps",
    "build": "tsc",
    "start": "node dist/main.js",
    "pretypecheck": "pnpm run build:deps",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "clean": "rm -rf dist"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/sensible": "^6.0.2",
    "@prisma/client": "^5.22.0",
    "@spartarena/byreal-adapter": "workspace:*",
    "@spartarena/sdk": "workspace:*",
    "@spartarena/shared": "workspace:*",
    "fastify": "^5.1.0",
    "pino": "^9.5.0",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
